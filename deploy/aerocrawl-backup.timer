[Unit]
Description=Nightly Aerocrawl SQLite backup
Requires=aerocrawl-backup.service

[Timer]
# Daily at 03:15 UTC (08:45 IST — low-traffic window)
OnCalendar=*-*-* 03:15:00 UTC
# Catch up if the VPS was offline during a scheduled run
Persistent=true
RandomizedDelaySec=300

[Install]
WantedBy=timers.target
