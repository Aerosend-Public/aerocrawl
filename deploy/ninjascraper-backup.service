[Unit]
Description=NinjaScraper SQLite backup
After=network.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/ninjascraper
ExecStart=/opt/ninjascraper/deploy/backup.sh
# Optional: point at an rclone remote for off-host backups
# Environment=RCLONE_REMOTE=hetzner-storage:ninjascraper-backups/
