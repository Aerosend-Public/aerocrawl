# .env.example — copy to .env and fill in. Only the first two are required for Tier 0.
#
# Aerocrawl uses capability tiers: every extra key you add unlocks more features.
# Run `python install/check-capabilities.py` any time to see what's active.

# ─── Tier 0 — Core (required) ────────────────────────────────────────────────
AEROCRAWL_DOMAIN=scraper.example.com
ADMIN_EMAIL=you@example.com

# Bootstrap generates these if unset — do not hand-edit on an existing install.
# DEFAULT_API_KEY=ac_live_...
# ADMIN_API_KEY=ac_admin_...

DATABASE_URL=sqlite+aiosqlite:////opt/aerocrawl/data/aerocrawl.db
REDIS_URL=redis://localhost:6379/0

# ─── Tier 1 — LLM features (free Gemini tier) ────────────────────────────────
# Unlocks: /extract, /search, image vision, visual mode, scan-PDF fallback.
# Get one at https://aistudio.google.com (free, no card).
# Comma-separate multiple keys for round-robin: GEMINI_API_KEY=AIza1,AIza2
GEMINI_API_KEY=

# ─── Tier 2 — Reddit + paywall bypass (free Cloudflare Workers) ──────────────
# See install/guides/04-cloudflare-workers.md
REDDIT_PROXY_URL=
CF_PROXY_URL=

# ─── Tier 3 — Residential proxies (~$8–30/mo) ────────────────────────────────
# See install/guides/05-proxybase.md — any HTTP proxy URL with auth works.
PROXY_URL=

# ─── Tier 4 — Hard anti-bot (pay-as-you-go) ──────────────────────────────────
# See install/guides/06-tavily.md
TAVILY_API_KEY=

# ─── Tier 5 — DataDome/PerimeterX class (pay-as-you-go, budget-gated) ───────
# See install/guides/07-zyte.md
ZYTE_API_KEY=
ZYTE_ENABLED=false
ZYTE_BUDGET_USD=30

# ─── Optional — opt in to anonymous install telemetry ────────────────────────
# If set to 1, bootstrap pings aerosend.io with version + tier count only. No PII.
ANONYMOUS_INSTALL_PING=
